$ORIGIN libwebsockets.org.
$TTL 86400
@	IN	SOA	ns1.libwebsockets.org. hostmaster.libwebsockets.org. (
			2020010101 ; serial
			3600       ; refresh
			1800       ; retry
			604800     ; expire
			86400      ; minimum TTL
			)
@	IN	NS	ns1.libwebsockets.org.

@	IN	A	46.105.127.147
tcp-fallback	IN	A	46.105.127.147
